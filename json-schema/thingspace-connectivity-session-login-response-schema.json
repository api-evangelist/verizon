{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/verizon/refs/heads/main/json-schema/thingspace-connectivity-session-login-response-schema.json",
  "title": "SessionLoginResponse",
  "description": "Session login response with token",
  "type": "object",
  "properties": {
    "sessionToken": {
      "type": "string",
      "description": "Session token for subsequent API calls",
      "example": "bcce3ea6-fe4f-4952-bacb-56e4639936a0"
    },
    "expiresIn": {
      "type": "integer",
      "description": "Token expiry in seconds",
      "example": 3600
    }
  }
}